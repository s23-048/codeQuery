# ===========================================
# CodeQuery Configuration (copy to .env)
# ===========================================

# LLM Provider
OPENAI_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Repository Storage
CLONE_DIR=./repos

# Search Settings
TOP_K_RETRIEVAL=20
TOP_K_FINAL=5

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Settings
STREAMLIT_PORT=8501
